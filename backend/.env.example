GEMINI_API_KEY=replace-me
# Fernet key for encrypting BYOK secrets at rest (any string; empty = BYOK off).
CONFIG_SECRET_KEY=
# UMLS UTS API key — required for SNOMED code retrieval (api retriever).
# Get one free at https://uts.nlm.nih.gov. RxNorm/ICD-10/LOINC need no key.
UMLS_API_KEY=
FHIR_BASE_URL=https://hapi.fhir.org/baseR4
DATABASE_URL=sqlite+aiosqlite:///./anamnesis.db
LOG_LEVEL=INFO
NGROK_DOMAIN=ogle-spinach-splendor.ngrok-free.dev
APP_ASSETS_BASE_URL=https://ogle-spinach-splendor.ngrok-free.dev
